<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.MainPage"
             BackgroundColor="#1C1B1F"
             Title="App Hotel">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" HorizontalOptions="FillAndExpand">

            <!-- Cabeçalho Principal do Aplicativo -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,10,0,10">
                <Label Text="&#x1F3E8; App Hotel"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#E6E1E5"
                       HorizontalOptions="Center" />
                <Label Text="Simulador de Reserva de Hospedagem"
                       FontSize="16"
                       TextColor="#CAC4D0"
                       HorizontalOptions="Center" />
                <BoxView HeightRequest="1" Color="#49454F" WidthRequest="200" HorizontalOptions="Center" Margin="0,8,0,0" />
            </VerticalStackLayout>

            <!-- Layout Responsivo (FlexLayout) -->
            <FlexLayout Wrap="Wrap" 
                        Direction="Row" 
                        JustifyContent="Center" 
                        AlignItems="Start" 
                        AlignContent="Center"
                        Margin="0,0,0,20">

                <!-- CARD 1: FORMULÁRIO DE ENTRADA -->
                <Border BackgroundColor="#25242A"
                        Stroke="#49454F"
                        StrokeShape="RoundRectangle 16"
                        Padding="24"
                        WidthRequest="400"
                        Margin="12"
                        HorizontalOptions="Center">
                    
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Dados da Hospedagem"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#E6E1E5"
                               HorizontalOptions="Start" />
                        
                        <BoxView HeightRequest="1" Color="#49454F" Margin="0,0,0,8" />

                        <!-- Data de Entrada -->
                        <Label Text="Data de Entrada (Check-in)"
                               FontSize="14"
                               TextColor="#CAC4D0"
                               FontAttributes="Bold" />
                        <DatePicker x:Name="dpCheckIn"
                                    TextColor="#E6E1E5"
                                    BackgroundColor="#2D2C31"
                                    DateSelected="DpCheckIn_DateSelected"
                                    Margin="0,0,0,4">
                            <DatePicker.Format>dd/MM/yyyy</DatePicker.Format>
                        </DatePicker>

                        <!-- Data de Saída -->
                        <Label Text="Data de Saída (Check-out)"
                               FontSize="14"
                               TextColor="#CAC4D0"
                               FontAttributes="Bold" />
                        <DatePicker x:Name="dpCheckOut"
                                    TextColor="#E6E1E5"
                                    BackgroundColor="#2D2C31"
                                    Margin="0,0,0,4">
                            <DatePicker.Format>dd/MM/yyyy</DatePicker.Format>
                        </DatePicker>

                        <!-- Tipo de Suíte -->
                        <Label Text="Tipo de Suíte"
                               FontSize="14"
                               TextColor="#CAC4D0"
                               FontAttributes="Bold" />
                        <Picker x:Name="pkSuite"
                                Title="Selecione a suíte desejada"
                                TextColor="#E6E1E5"
                                TitleColor="#938F99"
                                BackgroundColor="#2D2C31"
                                Margin="0,0,0,4">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Standard - R$ 120,00/dia</x:String>
                                    <x:String>Luxo - R$ 220,00/dia</x:String>
                                    <x:String>Premium - R$ 350,00/dia</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>

                        <!-- Quantidade de Hóspedes -->
                        <Label Text="Quantidade de Hóspedes"
                               FontSize="14"
                               TextColor="#CAC4D0"
                               FontAttributes="Bold" />
                        <Entry x:Name="txtHospedes"
                               Placeholder="Ex: 2"
                               PlaceholderColor="#938F99"
                               TextColor="#E6E1E5"
                               Keyboard="Numeric"
                               BackgroundColor="#2D2C31"
                               Margin="0,0,0,12" />

                        <!-- Botão Calcular -->
                        <Button x:Name="btnCalcular"
                                Text="Calcular Reserva"
                                FontSize="16"
                                FontAttributes="Bold"
                                BackgroundColor="#D0BCFF"
                                TextColor="#381E72"
                                CornerRadius="20"
                                HeightRequest="48"
                                Clicked="BtnCalcular_Clicked" />
                    </VerticalStackLayout>
                </Border>

                <!-- CARD 2: RESUMO DOS CÁLCULOS -->
                <Border x:Name="frameResultado"
                        BackgroundColor="#25242A"
                        Stroke="#49454F"
                        StrokeShape="RoundRectangle 16"
                        Padding="24"
                        WidthRequest="400"
                        Margin="12"
                        IsVisible="False"
                        HorizontalOptions="Center">
                    
                    <VerticalStackLayout Spacing="16">
                        <Label Text="&#x2705; Resumo da Reserva"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#E6E1E5"
                               HorizontalOptions="Center" />
                        
                        <BoxView HeightRequest="1" Color="#49454F" Margin="0,4" />
                        
                        <Label x:Name="lblTipoSuite" FontSize="14" TextColor="#E6E1E5" />
                        <Label x:Name="lblPeriodo" FontSize="14" TextColor="#E6E1E5" />
                        <Label x:Name="lblDiarias" FontSize="14" TextColor="#E6E1E5" />
                        <Label x:Name="lblHospedes" FontSize="14" TextColor="#E6E1E5" />
                        
                        <Label x:Name="lblTotal" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#D0BCFF" 
                               HorizontalTextAlignment="Center"
                               Margin="0,8" />
                        
                        <Button x:Name="btnAvancar"
                                Text="Avançar para Confirmação"
                                FontSize="16"
                                FontAttributes="Bold"
                                BackgroundColor="#381E72"
                                TextColor="#E8DEF8"
                                CornerRadius="20"
                                HeightRequest="48"
                                Clicked="BtnAvancar_Clicked" />
                    </VerticalStackLayout>
                </Border>

            </FlexLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>