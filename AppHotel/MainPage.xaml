<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.MainPage"
             BackgroundColor="#1C1B1F"
             Title="App Hotel">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" MaximumWidthRequest="500" HorizontalOptions="CenterAndExpand">

            <!-- Cabeçalho Principal do Aplicativo -->
            <Label Text="&#x1F3E8; App Hotel"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#E6E1E5"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0" />

            <Label Text="Simulador de Reserva de Hospedagem"
                   FontSize="14"
                   TextColor="#CAC4D0"
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="1" Color="#49454F" Margin="0,8" />

            <!-- Formulário de Entrada: Data de Entrada (Check-in) -->
            <Label Text="Data de Entrada (Check-in)"
                   FontSize="14"
                   TextColor="#CAC4D0"
                   FontAttributes="Bold" />
            <DatePicker x:Name="dpCheckIn"
                        TextColor="#E6E1E5"
                        BackgroundColor="#2D2C31"
                        DateSelected="DpCheckIn_DateSelected"
                        Margin="0,0,0,8">
                <DatePicker.Format>dd/MM/yyyy</DatePicker.Format>
            </DatePicker>

            <!-- Formulário de Entrada: Data de Saída (Check-out) -->
            <Label Text="Data de Saída (Check-out)"
                   FontSize="14"
                   TextColor="#CAC4D0"
                   FontAttributes="Bold" />
            <DatePicker x:Name="dpCheckOut"
                        TextColor="#E6E1E5"
                        BackgroundColor="#2D2C31"
                        Margin="0,0,0,8">
                <DatePicker.Format>dd/MM/yyyy</DatePicker.Format>
            </DatePicker>

            <!-- Formulário de Entrada: Seleção da Categoria da Suíte -->
            <Label Text="Tipo de Suíte"
                   FontSize="14"
                   TextColor="#CAC4D0"
                   FontAttributes="Bold" />
            <Picker x:Name="pkSuite"
                    Title="Selecione a suíte desejada"
                    TextColor="#E6E1E5"
                    TitleColor="#938F99"
                    BackgroundColor="#2D2C31"
                    Margin="0,0,0,8">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Standard - R$ 120,00/dia</x:String>
                        <x:String>Luxo - R$ 220,00/dia</x:String>
                        <x:String>Premium - R$ 350,00/dia</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <!-- Formulário de Entrada: Quantidade de Hóspedes -->
            <Label Text="Quantidade de Hóspedes"
                   FontSize="14"
                   TextColor="#CAC4D0"
                   FontAttributes="Bold" />
            <Entry x:Name="txtHospedes"
                   Placeholder="Ex: 2"
                   PlaceholderColor="#938F99"
                   TextColor="#E6E1E5"
                   Keyboard="Numeric"
                   BackgroundColor="#2D2C31"
                   Margin="0,0,0,16" />

            <!-- Botão de Ação para Calcular a Simulação -->
            <Button x:Name="btnCalcular"
                    Text="Calcular Reserva"
                    FontSize="16"
                    FontAttributes="Bold"
                    BackgroundColor="#D0BCFF"
                    TextColor="#381E72"
                    CornerRadius="20"
                    HeightRequest="48"
                    Clicked="BtnCalcular_Clicked"
                    Margin="0,0,0,12" />

            <!-- Contêiner (Border) Invisível por Padrão: Mostra o Resumo dos Cálculos -->
            <Border x:Name="frameResultado"
                    BackgroundColor="#25242A"
                    Stroke="#49454F"
                    StrokeShape="RoundRectangle 16"
                    Padding="20"
                    IsVisible="False"
                    Margin="0,8,0,0">
                <VerticalStackLayout Spacing="12">
                    <Label Text="&#x2705; Resumo da Reserva"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#E6E1E5"
                           HorizontalOptions="Center" />
                    
                    <BoxView HeightRequest="1" Color="#49454F" Margin="0,4" />
                    
                    <Label x:Name="lblTipoSuite" FontSize="14" TextColor="#E6E1E5" />
                    <Label x:Name="lblPeriodo" FontSize="14" TextColor="#E6E1E5" />
                    <Label x:Name="lblDiarias" FontSize="14" TextColor="#E6E1E5" />
                    <Label x:Name="lblHospedes" FontSize="14" TextColor="#E6E1E5" />
                    
                    <Label x:Name="lblTotal" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#D0BCFF" 
                           HorizontalTextAlignment="Center"
                           Margin="0,8" />
                    
                    <Button x:Name="btnAvancar"
                            Text="Avançar para Confirmação"
                            FontSize="16"
                            FontAttributes="Bold"
                            BackgroundColor="#381E72"
                            TextColor="#E8DEF8"
                            CornerRadius="20"
                            HeightRequest="48"
                            Clicked="BtnAvancar_Clicked"
                            Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>