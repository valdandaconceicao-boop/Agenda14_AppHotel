<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.SucessoPage"
             BackgroundColor="#1C1B1F"
             Title="Reserva Confirmada">

    <!-- Layout vertical centralizado para apresentar o feedback de sucesso de forma limpa e visível -->
    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="24" Padding="24" MaximumWidthRequest="500">

        <!-- Ícone visual de check (sucesso) -->
        <Label Text="&#x2705;"
               FontSize="80"
               HorizontalOptions="Center"
               Margin="0,0,0,8" />

        <Label Text="Reserva Confirmada&#x0a;com Sucesso!"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="#E6E1E5"
               HorizontalTextAlignment="Center"
               HorizontalOptions="Center" />

        <Label Text="Seu quarto foi reservado.&#x0a;Agradecemos a preferência!"
               FontSize="15"
               TextColor="#CAC4D0"
               HorizontalTextAlignment="Center"
               HorizontalOptions="Center"
               Margin="0,0,0,16" />

        <!-- Botão para voltar à tela de simulação anterior -->
        <Button x:Name="btnVoltar"
                Text="Voltar para o Início"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#D0BCFF"
                TextColor="#381E72"
                CornerRadius="20"
                HeightRequest="48"
                WidthRequest="220"
                Clicked="BtnVoltar_Clicked" />

    </VerticalStackLayout>

</ContentPage>