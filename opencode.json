{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com/mcp"
    },
    "sequential_thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["python", "-m", "mcp_server_fetch"],
      "enabled": true
    },
    "skool": {
      "type": "local",
      "command": ["node", "C:\\Users\\Tory\\skool-mcp\\dist\\index.js"],
      "enabled": true
    }
  },
  "tools": {
    "sequential_thinking_*": true,
    "fetch_*": true,
    "skool_*": true
  }
}